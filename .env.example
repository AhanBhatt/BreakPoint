# BreakPoint live judge credentials.
# Copy to .env and fill locally.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

OPENAI_JUDGE_MODEL=gpt-5.4-mini
ANTHROPIC_JUDGE_MODEL=claude-sonnet-5
