# BreakPoint live judge credentials.
# Copy to .env and fill locally.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

OPENAI_JUDGE_MODEL=gpt-5.4-mini
ANTHROPIC_JUDGE_MODEL=claude-sonnet-5
GEMINI_JUDGE_MODEL=gemini-2.5-flash

# Optional multi-model panel. If set, these override the single-model values above.
OPENAI_JUDGE_MODELS=gpt-5.5,gpt-5.4,o3,gpt-5.4-mini
ANTHROPIC_JUDGE_MODELS=claude-sonnet-5,claude-opus-4-8,claude-fable-5
GEMINI_JUDGE_MODELS=gemini-2.5-pro,gemini-2.5-flash

VLLM_JUDGE_ENDPOINT=http://127.0.0.1:8001
VLLM_JUDGE_MODEL=breakpoint-local-judge
VLLM_JUDGE_API_KEY=

BREAKPOINT_EXTERNAL_JUDGES=0
