VLLM_JUDGE_ENDPOINT=http://127.0.0.1:8001
VLLM_JUDGE_MODEL=breakpoint-local-judge
VLLM_JUDGE_API_KEY=

BREAKPOINT_EXTERNAL_JUDGES=0
